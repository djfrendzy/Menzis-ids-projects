# ── Dataset files (too large for GitHub, download separately) ────────────────
*.csv
*.pcap
*.pcapng

# ── Output figures and results (regenerated by running the pipeline) ──────────
outputs/
outputs_v2/

# ── Python cache ──────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.Python

# ── Virtual environments ───────────────────────────────────────────────────────
venv/
.venv/
env/
ENV/

# ── Jupyter Notebook checkpoints ──────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── OS files ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE/Editor settings ───────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Word documents (large binary files — optional to exclude) ─────────────────
# Uncomment the line below if you don't want to commit the .docx reports:
# *.docx
